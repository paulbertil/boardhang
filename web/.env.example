# Supabase credentials for the PWA. Copy to `web/.env` and fill in real values.
# The anon key is public-safe (RLS-protected) — it's meant to ship to the browser.
# If these are missing the app still runs; sign-in is simply disabled.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
